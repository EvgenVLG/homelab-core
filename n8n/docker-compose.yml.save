services:
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    restart: unless-stopped

    env_file:
      - /srv/docker/secrets/.env

    environment:
      - TZ=America/New_York
      - GENERIC_TIMEZONE=America/New_York

      - N8N_HOST=n8n.home.arpa
      - N8N_PROTOCOL=https
      - N8N_PORT=5678
/srv/docker/n8n/docker-compose.yml
      - N8N_EDITOR_BASE_URL=https://n8n.home.arpa
      - WEBHOOK_URL=https://n8n.home.arpa

      - N8N_PROXY_HOPS=1

    volumes:
      - ./data:/home/node/.n8n

    networks:
      - homelab

    labels:
      caddy: n8n.home.arpa
      caddy.tls: internal
      caddy.reverse_proxy: "{{upstreams 5678}}"

networks:
  homelab:
    external: true

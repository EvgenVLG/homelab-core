# Secrets
env/.env
.env
*.secret
*.key
*.pem

# Generated / runtime data
**/.DS_Store
**/__pycache__/
**/*.pyc
**/tmp/
**/cache/
**/logs/
**/sessions/

# Container data you usually do NOT want in git
data/**
backups/**

# But keep structure
!data/.gitkeep
!backups/.gitkeep

# Home Assistant runtime/state
ha/config/*.log
ha/config/home-assistant_v2.db
ha/config/home-assistant_v2.db-*
ha/config/.storage/*
!ha/config/.storage/.gitkeep

# Portainer runtime DB
portainer/data/*
!portainer/data/.gitkeep

# n8n runtime data
n8n/data/*
!n8n/data/.gitkeep

# AdGuard runtime/work files
adguard/work/*
!adguard/work/.gitkeep

# Homepage generated backups or transient data
homepage/backup-*/

# AdGuard mutable config/state
adguard/conf/AdGuardHome.yaml

# Home Assistant runtime leftovers
ha/config/.ha_run.lock
ha/config/home-assistant.log*
ha/config/*.db
ha/config/*.db-*

# Caddy runtime state
reverse-proxy/caddy/data/**

# Generated health snapshots
docs/health-latest.txt

